APP_NAME=Driply
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# URL publique exacte (liens signés e-mail, Storage::url). API prod typique :
# APP_URL=https://api.driply.app
APP_URL=https://driplyapp.fr

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=driply
DB_USERNAME=
DB_PASSWORD=

# DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

SANCTUM_STATEFUL_DOMAINS=localhost

# Clé https://serpapi.com — jamais dans Git
SERPAPI_KEY=
# Capture (POST /v1/scan, /v1/inspirations/scan) : serpapi = package Node Lens+Shopping | legacy = GPT-4o + PHP
VISION_SCAN_DRIVER=serpapi
# Nombre max de produits renvoyés par item (aligné sur le package SerpApi, défaut 10)
VISION_MAX_PRODUCTS_PER_ITEM=10
# Binaire Node pour bin/serpapi-outfit-search.mjs (après npm install à la racine Driply-api)
NODE_BINARY=node
# Timeout processus Node (secondes)
SERPAPI_PROCESS_TIMEOUT=120
# true = mocks sans appels SerpApi (tests uniquement)
SERPAPI_USE_MOCKS=false

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# FastSaverAPI (social download) : base https://fastsaverapi.com + token — jamais dans Git
FASTSERVER_URL=https://fastsaverapi.com
FASTSERVER_KEY=

# Page diagnostic https://ton-domaine/api-verif (optionnel : ?token=... si renseigné)
API_VERIF_TOKEN=

# Compatibilité app iOS : upload.php + api/sync_media.php (en-tête X-Driply-Key). Vide = upload sans clé (dev seulement).
DRIPLY_LEGACY_API_KEY=

# Lien du bouton « Ouvrir l'application » sur la page de vérification e-mail (schéma URL de l’app).
# DRIPLY_IOS_OPEN_APP_URL=driply://email-verified

# Après reset mot de passe (page web /reset-password/...) : ouverture de l’app (optionnel, défaut driply://).
# DRIPLY_IOS_OPEN_APP_AFTER_PASSWORD_RESET=driply://

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# E-mails (inscription, mot de passe oublié, etc.). Sans SMTP réel, rien n’est livré en boîte :
# si MAIL_MAILER absent, Laravel utilise « log » = contenu du mail seulement dans storage/logs (voir /api-verif).
# Hostinger SMTP (mot de passe uniquement dans .env sur le serveur, jamais dans Git)
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_ENCRYPTION=ssl
MAIL_USERNAME=contact@driplyapp.fr
MAIL_PASSWORD=
# Production API : noreply@driply.app — adapter selon domaine réel
MAIL_FROM_ADDRESS=noreply@driply.app
MAIL_FROM_NAME=Driply

# Durée de validité du lien « vérifier l’e-mail » (minutes)
EMAIL_VERIFICATION_EXPIRE=60

# En local, tu peux utiliser :
# MAIL_MAILER=log

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
