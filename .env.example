APP_NAME=Driply
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# URL publique exacte (liens signés e-mail, Storage::url). API prod typique :
# APP_URL=https://api.driply.app
APP_URL=https://driplyapp.fr

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=driply
DB_USERNAME=
DB_PASSWORD=

# DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

SANCTUM_STATEFUL_DOMAINS=localhost

# Clé https://serpapi.com (Lens + Shopping en PHP) — jamais dans Git
SERPAPI_KEY=
# Capture / scan (défaut) : legacy = SerpApi Google Lens (image) puis Google Shopping (texte), **sans GPT**, **sans Node**.
# serpapi = script Node bin/serpapi-outfit-search.mjs (VPS avec node + paquet npm).
VISION_SCAN_DRIVER=legacy
# Max produits renvoyés au client après scoring (défaut 15 côté config si absent)
# Offres max renvoyées par scan après scoring (ex. 45 → 10 visibles puis « Voir plus » +30 côté app)
VISION_MAX_PRODUCTS_PER_ITEM=45
# Minimum d’offres pour accepter un scan (sinon 422). Défaut 10 si absent.
VISION_MIN_SCAN_RESULTS=10
# Grand côté demandé dans les URLs image Google (=w/-h/, =s/) pour des aperçus plus nets (défaut 1600)
# VISION_MAX_GOOGLE_IMAGE_EDGE=1600
# Résultats bruts max par appel Lens/Shopping, requêtes Shopping dérivées des titres Lens, candidats après dédup
# VISION_MAX_RAW_RESULTS=30
# VISION_MAX_SHOPPING_QUERIES=5
# VISION_MAX_CANDIDATES_AFTER_DEDUP=40
# OpenAI : plus utilisé pour la capture legacy ; utile pour d’autres features éventuelles
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Uniquement si VISION_SCAN_DRIVER=serpapi : chemin absolu vers node (ex. /usr/bin/node)
NODE_BINARY=node
SERPAPI_PROCESS_TIMEOUT=120
SERPAPI_USE_MOCKS=false
# SerpAPI / Google Lens : APP_URL doit être l’URL HTTPS publique du site. Les captures vont sous storage/scans/ ;
# l’app génère https://…/driply-public/scans/… (pas seulement /storage/) pour que SerpAPI puisse télécharger l’image.

# FastSaverAPI (social download) : base https://fastsaverapi.com + token — jamais dans Git
FASTSERVER_URL=https://fastsaverapi.com
FASTSERVER_KEY=

# Page diagnostic https://ton-domaine/api-verif (optionnel : ?token=... si renseigné)
API_VERIF_TOKEN=

# Compatibilité app iOS : upload.php + api/sync_media.php (en-tête X-Driply-Key). Vide = upload sans clé (dev seulement).
DRIPLY_LEGACY_API_KEY=

# Lien du bouton « Ouvrir l'application » sur la page de vérification e-mail (schéma URL de l’app).
# DRIPLY_IOS_OPEN_APP_URL=driply://email-verified

# Après reset mot de passe (page web /reset-password/...) : ouverture de l’app (optionnel, défaut driply://).
# DRIPLY_IOS_OPEN_APP_AFTER_PASSWORD_RESET=driply://

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# E-mails (inscription, mot de passe oublié, etc.). Sans SMTP réel, rien n’est livré en boîte :
# si MAIL_MAILER absent, Laravel utilise « log » = contenu du mail seulement dans storage/logs (voir /api-verif).
# Hostinger SMTP (mot de passe uniquement dans .env sur le serveur, jamais dans Git)
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_ENCRYPTION=ssl
MAIL_USERNAME=contact@driplyapp.fr
MAIL_PASSWORD=
# Production API : noreply@driply.app — adapter selon domaine réel
MAIL_FROM_ADDRESS=noreply@driply.app
MAIL_FROM_NAME=Driply

# Durée de validité du lien « vérifier l’e-mail » (minutes)
EMAIL_VERIFICATION_EXPIRE=60

# En local, tu peux utiliser :
# MAIL_MAILER=log

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
