APP_NAME=Driply
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://api.driply.app

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=driply
DB_USERNAME=
DB_PASSWORD=

# DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

SANCTUM_STATEFUL_DOMAINS=localhost

SERPAPI_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

FASTSERVER_URL=
FASTSERVER_KEY=

# Page diagnostic https://ton-domaine/api-verif (optionnel : ?token=... si renseigné)
API_VERIF_TOKEN=

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Hostinger SMTP (mettre le mot de passe uniquement dans .env sur le serveur, jamais dans Git)
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_ENCRYPTION=ssl
MAIL_USERNAME=contact@driplyapp.fr
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=contact@driplyapp.fr
MAIL_FROM_NAME=Driply

# Durée de validité du lien « vérifier l’e-mail » (minutes)
EMAIL_VERIFICATION_EXPIRE=60

# En local, tu peux utiliser :
# MAIL_MAILER=log

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
